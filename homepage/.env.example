# Domaine public principal (ex: monsite.ddns.net ou mondomaine.fr)
DOMAIN=

# Sous-domaine pour l'interface de gestion Homer Manager
MANAGER_SUBDOMAIN=manager

# Nom du certresolver configuré dans Traefik (ex: letsencrypt, myresolver)
CERT_RESOLVER=letsencrypt

# Identifiants Homer Manager
MANAGER_USER=admin
MANAGER_PASSWORD=

# Clé secrète Flask pour les sessions (générer avec : openssl rand -hex 32)
SECRET_KEY=
